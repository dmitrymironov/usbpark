{
	setSoundNotificationMode(m_settings->soundNotification());
}

void Novorado::Parking::ParkAssist::setSoundNotificationMode(Novorado::Parking::ParkAssist::SOUND_NOTIFICATION_MODE snm)
{
	if(snm==SNM_VOICE){

		m_settings->setSoundNotification(SNM_VOICE);

		if(soundThread){

			soundThread->quit();
			soundThread->wait();

			if(m_webcam) clearScreenAndStopVideo();

			delete soundThread;
			soundThread=NULL;
			}


		if(!voiceThread) {
			voiceThread = new VoiceNotification(m_settings);
			connect(this,SIGNAL(deviceDisconnected()),voiceThread,SLOT(onDeviceDisconnected()));
			connect(this,SIGNAL(deviceConnected()),voiceThread,SLOT(onDeviceConnected()));
			}

		voiceThread->start();

		return;
		}

	else if(snm==SNM_TONES){

		m_settings->setSoundNotification(SNM_TONES);

		if(voiceThread) {
			voiceThread->suspendSignals();
			}


		QMutexLocker lk(&m_vlcLibMutex);
		soundThread = new SoundThread(this);
		soundThread->start();
		soundThread->setPriority(QThread::LowestPriority);
		return;
		}

	std::stringstream s;

	s << "Unknown SNM code '" << snm << "' (voice - " << SNM_VOICE << ", tones - " << SNM_TONES << ")";

	throw Novorado::LogicErrorException(s.str());
}

void Novorado::Parking::ParkAssist::muteSound(bool f){
	flags.muteSound=f;

	if(flags.muteSound){
		if(voiceThread){
			voiceThread->suspendSignals();
			}
		if(soundThread){
			soundThread->quit();
			soundThread->wait();
			delete soundThread;
			soundThread=NULL;
			}

		} else startSound();
	}

