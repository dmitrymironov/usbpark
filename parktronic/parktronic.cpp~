class PrintTimeStampAndCatchIO {
	std::string t(){
		return QTime::currentTime().toString().toAscii().constData();
		}
	std::string d(){
		return QDate::currentDate().toString("dd.MM.yyyy").toAscii().constData();
		}

	public:

		PrintTimeStampAndCatchIO(){
			Novorado::Parking::Settings s;
			start(&s);
			}

		void start(Novorado::Parking::Settings* s){

			if(s->logUSB()){
				putenv("USB_DEBUG=10");
				}

			std::string fn = s->logFileName().toUtf8().constData();

			std::cout << "Log to console:" << (s->logToConsoleOnly()?fn.c_str():"no") << std::endl;

			if(!s->logToConsoleOnly() && s->logToFile()) {

				std::cout << "Writing log to " << fn << std::endl;

				bool cl=s->cleanLog();

				// Nop, we're not gonna clean it
				// policy has changed - user has to unselect if(cl) s->setCleanLog(false);

				FILE *flog = freopen(fn.c_str(),cl?"w":"a",stdout);
				fclose(stderr);
				*stderr = *flog;
				}

			std::cout << "====================== APPLICATION STARTED: " << d() << " " << t() << std::endl;
			}
		~PrintTimeStampAndCatchIO(){
			std::cout << "======================== APPLICATION ENDED: " << d() << " " << t() << std::endl;

			fflush(stdout);
			fflush(stderr);
			}
	};

void lower_char(char& c)
{
	c=::tolower(c);
}

void removeInitialMinus(std::string& s)
{
	while(s.length() && s[0]=='-') s.erase(0,1);
	std::for_each(s.begin(),s.end(),lower_char);
}

using namespace Novorado;

std::string parkAssistVersion;

int main(int argc, char* argv[])
{
	std::list<std::string> largs;
	std::copy(argv,argv+(argc),std::back_inserter(largs));

	std::for_each(largs.begin(),largs.end(),removeInitialMinus);

	std::list<std::string>::iterator l;

	//bool flagConfig = (std::find(largs.begin(),largs.end(),"config")!=largs.end());

	if((l=std::find(largs.begin(),largs.end(),"unzip"))!=largs.end()){

		l++;

		QString inFileName(l->c_str());

		std::cout << "Reading " << inFileName.toAscii().constData() << std::endl;

		if(!QFileInfo(inFileName).size()) {
			std::cerr << "Wrong file name, or permissions!" << std::endl;
			return 3;
			}

		QFile f(inFileName);
		f.open(QIODevice::ReadOnly);
		QByteArray in=f.readAll();
		f.close();

		QByteArray ba = qUncompress(in);

		QFileInfo fi(inFileName);
		QString on=fi.baseName()+".txt";

		QFile of(on);
		of.open(QIODevice::WriteOnly | QIODevice::Text);
		of.write(ba);
		of.close();

		std::cout << "Data from " << inFileName.toAscii().constData() << " (size " << QFileInfo(inFileName).size() << "b) was unzipped to "
			<< on.toAscii().constData()
			<< " (uncompressed size " << QFileInfo(on).size() << "b)"
			<< std::endl;
		return 1;
		}

	int retVal=0;
	std::string retMessage;

	try {

//  	QTextCodec::setCodecForCStrings(QTextCodec::codecForName("UTF-8"));
	do {

		PtrHolder<PrintTimeStampAndCatchIO> pts;
		bool flagPrintVersionAndExit=(std::find(largs.begin(),largs.end(),"version")!=largs.end());

		if(!flagPrintVersionAndExit){
			pts = (new PrintTimeStampAndCatchIO);
			}

		Novorado::Version ver("parker",MAJOR_VERSION,MINOR_VERSION,PATCH_VERSION);
		ver.cmdline(argc,argv);

		if((l=std::find(largs.begin(),largs.end(),"--noupdate"))==largs.end()){
			if(ver.hasUpdate(argv[0],"Parking Assistant")){
				// that will restart the process
				ver.update();
				}
			}


		// initialize version
		parkAssistVersion=ver.getVersion();

		QApplication app(argc, argv);

		char const *x[] = {"parker", "parkerD", "audi", "audiD", "oodd", "ooddD","loganalyz","loganalyzD"};
		std::set<std::string> apps(x, x + sizeof(x) / sizeof(*x));

		if(Novorado::Process::count(apps)>1) throw std::logic_error(
			QObject::tr("Another copy of application is already running")
				.toUtf8().constData());

		qRegisterMetaType < std::string > ( "std::string" );
		qRegisterMetaType < LineId > ( "LineId" );
		qRegisterMetaType < HeadId > ( "HeadId" );
		qRegisterMetaType < SpeechSynth::SST_LANG > ( "SpeechSynth::SST_LANG" );
		qRegisterMetaType < Novorado::HeadLogicNumber > ("Novorado::HeadLogicNumber" );
		qRegisterMetaType < Novorado::DistanceCM > ("Novorado::DistanceCM" );
		qRegisterMetaType < std::vector<unsigned char> > ("std::vector<unsigned char>");

		Novorado::Parking::ParkAssist p(argc,argv);

	//	pts.start(p.settings());
		p.setWindowTitle((std::string("Parking Assistant")/*+parkAssistVersion*/).c_str());

		app.setActiveWindow(&p);

		retVal=app.exec();

		std::cout << "Application exited (" << retVal << ")" << std::endl;

	} while(retVal==APP_RELOAD_CODE);

	return retVal;

	} catch ( const Novorado::LogicErrorException& err){
		retMessage = "Application failed: ";
		retMessage += err.what();
		std::cerr <<  retMessage  << std::endl;
		retVal=1;
		}

	catch ( const std::logic_error& err) {
		retMessage = "Application failed with logic error: ";
		retMessage += err.what();
		std::cerr << retMessage << std::endl;
		retVal= 3;
		}

	catch ( ... ) {
		retMessage ="Application failed: unknown exception thrown" ;
		std::cerr << "Application failed: unknown exception thrown"  << std::endl;
		retVal=2;
		}

	if(retVal){
		QApplication errorApp(argc,argv);
		// Error happened
		QMessageBox::critical(NULL, "Parktronic Application",
                                retMessage.c_str());
		}

	return retVal;
}
