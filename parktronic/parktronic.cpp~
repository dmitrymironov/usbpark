void WebCamThread::run()
{
	VlcPlayer vp(parkAss->settings(),this);

	connect(parkAss,SIGNAL(placeVideo(const QRect&)),this,SLOT(resize(const QRect&)));

	connect(this,SIGNAL(requestedStart()),&vp,SLOT(init()),Qt::QueuedConnection);
	connect(this,SIGNAL(requestedStop()),&vp,SLOT(stop()),Qt::QueuedConnection);

	// It is going to be event driven than
	exec();
}

