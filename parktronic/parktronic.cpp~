void SoundPlayer::play(const std::string& _f)
{
	// Ugly "static" instead of member to suppress festival warnings
	static std::map<std::string,EST_Wave> m_wave;
	std::map<std::string,EST_Wave>::iterator i=m_wave.find(_f);
	if ( i == m_wave.end() ) {
		EST_Wave& w=m_wave[_f];
		w.load(_f.c_str());
		i=m_wave.find(_f);
		}

	EST_Option play_wave_options;
 	play_wave_options.add_item("-quality","HIGH");
	play_wave(i->second,play_wave_options);

	std::cout << "Playing wave " << _f << std::endl;

	emit finishedPlaying();
}
