		std::cout << "User settings command not to use video" << std::endl;
		return 0;
		} else {
			std::cout << "Video device: " << mrl.toAscii().constData() << std::endl;
			}

	if(cameraFrames.find(mrl)==cameraFrames.end()){

		cameraFrames[mrl] = (m_frame = new VideoFrame);

		} else m_frame = cameraFrames[mrl].get();

	connect(
		videoFrame(), SIGNAL(haveImage(Novorado::Media::VideoFrame*)),
		m_thread->owner(), SLOT(onWebCamUpdate(Novorado::Media::VideoFrame*))
		);

	// From that point, we'll start constructing the video poller
	//f_noVideo=false;

	std::cout << "Starting video thread" << std::endl;

//	QMutexLocker lk(&m_frame->mutex);

//VMEM	char clock[64]="xxx", cunlock[64]="xxx", cdata[64]="xxx"; //, dshow_arg[64]="";
//VMEM	char width[32]="xxx", height[32]="xxx", pitch[32]="xxx";

	#if	defined MINGW
	char plugins[MAX_PATH]="";

	QString p=QDir::toNativeSeparators(QString(m_settings->videolanPath().c_str())+"/plugins");

	sprintf(plugins,"%s",p.toAscii().constData());

	std::cout << "Loading video plugins: \"" << plugins << "\"" << std::endl;

	// Properly formatted dshow string
	//  dshow:// :dshow-vdev="USB2.0 UVC 1.3M WebCam" :dshow-adev=none
	std::string /*dshowOption="-vvv", */dshowVDev="-vvv",dshowSize="320x240";

	if(mrl!="dshow://"){
		//dshowOption=":dshow-vdev",
		dshowVDev = mrl.toUtf8().constData();
		std::cout << "Using special dshow video device \"" << dshowVDev.c_str() << "\"" << std::endl;
		std::stringstream r;
		r << VIDEOWIDTH << "x" << VIDEOHEIGHT;
		dshowSize=r.str();
		}
	#endif

	char const *vlc_argv[] =
	{
		"-q",
	#if	defined PRINT_CALLS || defined NOVORADO_DEBUG
		"-vvv",
	#endif
	#if	defined	MINGW
		"--plugin-path", plugins,
		"--dshow-adev", "none",
		"--dshow-vdev",dshowVDev.c_str(),
		"--dshow-size",dshowSize.c_str(),
		"--language","en", // windows specific on moment of update
	#else
//		"--reset-plugins-cache",
		"--noaudio",
	#endif
//		"--ignore-config", /* Don't use VLC's config files */
//VMEM		"--vout", "vmem",
//VMEM		"--vmem-width", width,
//VMEM		"--vmem-height", height,
//VMEM		"--vmem-pitch", pitch,
//VMEM		"--vmem-chroma", "RV16",
//VMEM		"--vmem-lock", clock,
//VMEM		"--vmem-unlock", cunlock,
//VMEM		"--vmem-data", cdata,
	};

	int vlc_argc = sizeof(vlc_argv) / sizeof(*vlc_argv);

	/*
	*  Initialise libVLC
	*/
//VMEM	sprintf(clock, "%lld", (long long int)(intptr_t)lock);
//VMEM	sprintf(cunlock, "%lld", (long long int)(intptr_t)unlock);
//VMEM	sprintf(cdata, "%lld", (long long int)(intptr_t)m_frame);
//VMEM	sprintf(width, "%i", VIDEOWIDTH);
//VMEM	sprintf(height, "%i", VIDEOHEIGHT);
//VMEM	sprintf(pitch, "%i", VIDEOWIDTH * 2);

	std::cout << "Initializing SDL" << std::endl;

	// Has to be created before passing to libvlc
	m_frame->surf = SDL_CreateRGBSurface(
		SDL_SWSURFACE,
		VIDEOWIDTH,
		VIDEOHEIGHT,
		16, 0x001f, 0x07e0, 0xf800, 0);

	std::cout << "Creating new instance" << std::endl;

	libvlc = libvlc_new(vlc_argc, vlc_argv);

	std::cout << "Setting media" << std::endl;

	#if	!defined	MINGW
	m = libvlc_media_new_path(libvlc, mrl.toAscii().constData());
	#else
	m = libvlc_media_new_path(libvlc, "dshow://");
	#endif

	if(!m) {
		std::cout << "Looks like camera is busy" << std::endl;
		}

	std::cout << "Starting media player" << std::endl;

	mp = libvlc_media_player_new_from_media(m);

	if(!mp) {
		std::cout << "Unable to launch media player on selected media" << std::endl;
		}

	std::cout << "Releasing media" << std::endl;
	libvlc_media_release(m);

	std::cout << "Setting up video hook" << std::endl;
	libvlc_video_set_callbacks(mp, lock, unlock, display, m_frame);
    libvlc_video_set_format(mp, "RV16", VIDEOWIDTH, VIDEOHEIGHT, VIDEOWIDTH*2);

	std::cout << "Initiated playback" << std::endl;
	libvlc_media_player_play(mp);

	std::cout << "Player initialization complete" << std::endl;
	m_frame->resetTime();
	return 0;
}

