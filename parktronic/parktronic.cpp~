void SoundThread::run()
{
	if(dude!=NULL) throw Novorado::LogicErrorException("SoundThread::run() - sound player already initialized");
	dude = new SoundPlayer();

	connect(
		this, SIGNAL(makeSound(const std::string&)),
		dude, SLOT(play(const std::string&))
		);

	connect(
		dude,SIGNAL(finishedPlaying()),
		parkAss, SLOT(enableBeeps())
		);

	connect(
		parkAss, SIGNAL(makeSound(const std::string&)),
		dude, SLOT(play(const std::string&))
		);

	exec();

	delete dude;
	dude=NULL;
}

