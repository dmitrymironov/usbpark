void VlcPlayer::stop()
{
	// Check if video has loaded
	if(!hasVideo()) return;

	disconnect(
		videoFrame(), SIGNAL(haveImage(Novorado::Media::VideoFrame*)),
		m_thread->owner(), SLOT(onWebCamUpdate(Novorado::Media::VideoFrame*))
		);

	// It will complain
	//m_thread->owner()->onWebCamUpdate(m_frame, true);

	/*
	* Stop stream and clean up libVLC
	*/
	std::cout << "Stopping media player .." << std::endl;

	libvlc_media_player_stop(mp);

	QMutexLocker vlclk(&m_vlcLibMutex);
	std::cout << "Video thread locked" << std::endl;

	std::cout << "Releasing media player .." << std::endl;
	libvlc_media_player_release(mp);
	libvlc_release(libvlc);

	std::cout << "Media access shut down" << std::endl;

	m_frame=NULL;
	mp=NULL;
	libvlc=NULL;
}

